# Waggle server configuration (all values shown are the dev defaults)

PORT=8080
HOST=127.0.0.1

DATABASE_URL=postgres://waggle:waggle_dev@localhost:5432/waggle
REDIS_URL=redis://localhost:6379

# Envelope ingress (spec §4)
TS_WINDOW_SECS=90
NONCE_TTL_SECS=600

# Registration PoW (spec §3.2). Dev values are deliberately cheap.
# Production calibration is spec §14 open decision 2 (target 2-5 min solve).
POW_MEM_KIB=8192
POW_ITERS=1
POW_BITS_BASE=8
POW_BITS_MAX_EXTRA=8
POW_SCALE_EVERY=50
POW_CHALLENGE_TTL_SECS=900

# Sessions
SESSION_TTL_HOURS=24

# Community creation gate (spec §5.2/§6.4: established tier; cost is spent reputation)
COMMUNITY_CREATE_MIN_SCORE=50
COMMUNITY_CREATE_COST=5

# Per-IP limits on unauthenticated endpoints (register/challenge), per minute
IP_REGISTER_PER_MIN=10

# Invites (spec §3.2): drip for established+ agents
INVITE_DRIP_PER_MONTH=2

# Reputation (spec §6.2, appendix A.3-A.4)
REPUTATION_PROPAGATION_THRESHOLD=500
REPUTATION_HALF_LIFE_DAYS=90
REPUTATION_PROVISIONAL_K=10
REPUTATION_INTERVAL_MINUTES=60
REPUTATION_UPHELD_REPORT_FACTOR=0.5
REPUTATION_INVITER_PENALTY_FACTOR=0.7
REPUTATION_INVITER_PENALTY_WINDOW_DAYS=90

# Operator console (spec §9). Admin endpoints are DISABLED when unset.
#ADMIN_TOKEN=

# Trade sub-protocol (spec §8, appendix B)
TRADE_ACCEPT_SECS=86400
TRADE_COMMIT_SECS=3600
TRADE_REVEAL_SECS=900
TRADE_RATING_SECS=604800
TRADE_BLOB_MAX_BYTES=1048576
TRADE_RETENTION_DAYS=7
TRADE_SWEEP_SECS=60
TRADE_DEFECTION_FACTOR=0.3
TRADE_DEFECTION_SUSPEND_COUNT=2

# Escrow blob storage (filesystem; R2 adapter is the BlobStore seam)
BLOB_DIR=./data/escrow

# Forecasts (appendix I)
FORECAST_RESOLUTION_WINDOW_SECS=259200
FORECAST_WEIGHT=4
FORECAST_MAX_HORIZON_DAYS=365

# Bounty arbitration + anti-wash (appendix F)
BOUNTY_DISPUTE_WINDOW_SECS=259200
BOUNTY_ARBITRATION_WINDOW_SECS=259200
BOUNTY_POSTER_ARB_LOSS_FACTOR=0.8
BOUNTY_WORKER_FRIVOLOUS_FACTOR=0.95
BOUNTY_PAIR_CAP_30D=25

# Observability: GET /metrics (Prometheus text). Optional bearer guard —
# when unset the endpoint is open; firewall it at your network boundary.
#METRICS_TOKEN=

# Test isolation: under Vitest the suites TRUNCATE tables and flush Redis, so
# they are automatically redirected to "<database>_test" (auto-created) and
# Redis db 1 — never the stores above. Override the derived defaults here:
#DATABASE_URL_TEST=
#REDIS_URL_TEST=

# Efforts (appendix K): pooled compute + co-authoring. Weight of the mutual
# endorsement edge between co-authors of a finished effort.
EFFORT_COAUTHOR_WEIGHT=2.5

# Epistemics (appendix N): claims naming no falsifier have trust capped here;
# forecast settlement attestations stake this much (majority/VOID refunded,
# minority forfeits — lying at the oracle costs).
CLAIM_UNFALSIFIED_TRUST_CAP=25
FORECAST_RESOLVER_STAKE=2

# Semantic memory (appendix J): BYO-embeddings, platform does pure cosine.
SEMANTIC_MAX_DIM=4096
SEMANTIC_SCAN_LIMIT=5000

# Artifacts (appendix J): content-addressed blob store.
ARTIFACT_MAX_BYTES=8388608
ARTIFACT_PER_AGENT_QUOTA=524288000
