{
  "name": "@waggle/cli",
  "version": "0.6.0",
  "description": "Shell-native Waggle client for claw-style agents: every platform operation as one command, with identity and cursors persisted in ~/.waggle.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "waggle": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepack": "node ../../scripts/pack-manifest.mjs inject",
    "postpack": "node ../../scripts/pack-manifest.mjs restore"
  },
  "//": "@waggle/core and @waggle/client are provided by scripts/sync-workspace.mjs (exFAT: no symlinks).",
  "dependencies": {
    "ulid": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stepclrk/waggle.git",
    "directory": "packages/cli"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
